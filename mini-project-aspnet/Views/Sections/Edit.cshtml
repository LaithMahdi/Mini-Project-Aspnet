@model mini_project_aspnet.Models.Section

@{
    ViewData["Title"] = "Edit Section";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />

<div class="page-wrapper">

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-left">
            <h1>Edit Section</h1>
            <p>Update section information and settings</p>
        </div>
    </div>

    <!-- Breadcrumb -->
    <div class="nav-breadcrumb">
        <a asp-action="Index">Sections</a>
        <span class="separator">/</span>
        <span>Edit</span>
    </div>

    <!-- Form Card -->
    <div class="card-modern" style="max-width: 600px;">
        <div class="card-header">
            <h2>Section Details</h2>
        </div>

        <form asp-action="Edit">
            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <!-- Hidden ID -->
            <input type="hidden" asp-for="id" />

            <!-- Name Field -->
            <div class="form-group-custom">
                <label asp-for="name" class="form-label-custom">Section Name</label>
                <input asp-for="name" class="form-control-custom" placeholder="e.g., 1st Year Section A" />
                <span asp-validation-for="name" class="form-error"></span>
            </div>

            <!-- Code Field -->
            <div class="form-group-custom">
                <label asp-for="code" class="form-label-custom">Section Code</label>
                <input asp-for="code" class="form-control-custom" placeholder="e.g., SEC-1A" />
                <span asp-validation-for="code" class="form-error"></span>
            </div>

            <!-- Active Status -->
            <div class="form-group-custom">
                <div class="form-check-custom">
                    <input type="checkbox" class="form-check-input-custom" asp-for="isActive" id="isActive" />
                    <label for="isActive" class="form-check-label-custom">
                        Mark this section as active
                    </label>
                </div>
            </div>

            <!-- Created/Updated Info -->
            <div style="background: var(--bg-light); border-radius: 8px; padding: 1rem; margin-bottom: 1.5rem;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; font-size: 0.85rem;">
                    <div>
                        <span class="text-secondary">Created:</span>
                        <div style="color: var(--text-dark); font-weight: 500;">@Model.createdAt.ToString("MMM dd, yyyy HH:mm")</div>
                    </div>
                    <div>
                        <span class="text-secondary">Last Updated:</span>
                        <div style="color: var(--text-dark); font-weight: 500;">@Model.updatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <button type="submit" class="btn-custom btn-primary-gradient">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                    Save Changes
                </button>
                <a asp-action="Index" class="btn-custom btn-secondary" style="justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12" />
                        <polyline points="12 19 5 12 12 5" />
                    </svg>
                    Cancel
                </a>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
