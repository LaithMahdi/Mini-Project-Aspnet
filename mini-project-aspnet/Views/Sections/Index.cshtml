@model IEnumerable<mini_project_aspnet.Models.Section>
@{
    ViewData["Title"] = "Sections";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />

<div class="page-wrapper">

    <!-- Header -->
    <div class="page-header">
        <div class="page-header-left">
            <h1>Sections</h1>
            <p>Manage all academic sections in the system</p>
        </div>
        <div class="page-header-right">
            <a asp-action="Create" class="btn-custom btn-primary-gradient">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                New Section
            </a>
        </div>
    </div>

    <!-- Stats strip -->
    <div class="stats-strip">
        <div class="stat-card accent">
            <div class="stat-label">Total Sections</div>
            <div class="stat-num">@Model.Count()</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Active</div>
            <div class="stat-num" style="color: var(--success-color);">@Model.Count(s => s.isActive)</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Inactive</div>
            <div class="stat-num" style="color: var(--danger-color);">@Model.Count(s => !s.isActive)</div>
        </div>
    </div>

    <!-- Table -->
    <div class="card-modern" style="padding: 0; overflow: hidden;">
        <table class="table-modern">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.name)</th>
                    <th>@Html.DisplayNameFor(model => model.code)</th>
                    <th>@Html.DisplayNameFor(model => model.isActive)</th>
                    <th>@Html.DisplayNameFor(model => model.createdAt)</th>
                    <th>@Html.DisplayNameFor(model => model.updatedAt)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="3" y="3" width="18" height="18" rx="3" />
                                    <path d="M9 9h6M9 12h6M9 15h4" />
                                </svg>
                                <p>No sections found. <a asp-action="Create">Create the first one.</a></p>
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span style="font-weight: 600; color: var(--primary-color);">@Html.DisplayFor(m => item.name)</span></td>
                        <td><span class="badge-code">@Html.DisplayFor(m => item.code)</span></td>
                        <td>
                            @if (item.isActive)
                            {
                                <span class="badge-active yes"><span class="dot"></span>Active</span>
                            }
                            else
                            {
                                <span class="badge-active no"><span class="dot"></span>Inactive</span>
                            }
                        </td>
                        <td><span style="color: var(--text-secondary); font-size: 0.82rem;">@item.createdAt.ToString("MMM dd, yyyy")</span></td>
                        <td><span style="color: var(--text-secondary); font-size: 0.82rem;">@item.updatedAt.ToString("MMM dd, yyyy")</span></td>
                        <td>
                            <div class="action-links">
                                <a asp-action="Edit" asp-route-id="@item.id" class="action-btn edit">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                    Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.id" class="action-btn details">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="11" cy="11" r="8" />
                                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                                    </svg>
                                    Details
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.id" class="action-btn delete">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6l-1 14H6L5 6" />
                                        <path d="M10 11v6M14 11v6" />
                                        <path d="M9 6V4h6v2" />
                                    </svg>
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>