<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - mini_project_aspnet</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom-styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/mini_project_aspnet.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />
    <style>
        /* ============= SIDEBAR STYLES ============= */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 260px;
            height: 100vh;
            overflow-y: auto;
            background: linear-gradient(180deg, #fff 0%, #f8faff 100%);
            border-right: 1.5px solid var(--border-color);
            padding: 1.5rem 1rem;
            z-index: 100;
            font-family: 'DM Sans', sans-serif;
        }

        .sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: transparent;
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 3px;
        }

        .sidebar::-webkit-scrollbar-thumb:hover {
            background: var(--text-secondary);
        }

        /* Sidebar Brand/Logo */
        .sidebar-brand {
            display: block;
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--primary-color);
            text-decoration: none;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1.5px solid var(--border-color);
            transition: opacity 0.2s;
        }

        .sidebar-brand:hover {
            opacity: 0.8;
            color: var(--primary-color);
            text-decoration: none;
        }

        /* Sidebar Navigation */
        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .sidebar-nav-item {
            margin: 0;
        }

        .sidebar-nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0.75rem 1rem;
            color: var(--text-dark);
            text-decoration: none;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

        .sidebar-nav-link:hover {
            background: var(--info-bg);
            color: var(--primary-light);
            border-left-color: var(--primary-light);
            text-decoration: none;
        }

        .sidebar-nav-link.active {
            background: var(--primary-gradient);
            color: white;
            border-left-color: white;
        }

        .sidebar-nav-link svg {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
        }

        /* Sidebar User Section */
        .sidebar-user-section {
            margin-top: auto;
            padding-top: 1rem;
            border-top: 1.5px solid var(--border-color);
        }

        .sidebar-user-info {
            background: var(--bg-light);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 0.75rem;
        }

        .sidebar-user-role {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 0.3rem;
        }

        .sidebar-user-name {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--primary-color);
            word-break: break-word;
        }

        .sidebar-logout {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0.75rem 1rem;
            background: var(--danger-bg);
            color: var(--danger-color);
            border: 1.5px solid #fecaca;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
        }

        .sidebar-logout:hover {
            background: #fee2e2;
            color: var(--danger-color);
            text-decoration: none;
            transform: translateY(-1px);
        }

        .sidebar-logout svg {
            width: 16px;
            height: 16px;
        }

        /* Main content offset to avoid sidebar overlap */
        .main-content {
            margin-left: 260px;
            min-height: 100vh;
            padding: 1.5rem 2rem;
            background: #fafbfc;
        }

        /* Responsive: collapse sidebar on small screens */
        @@media (max-width: 991px) {
            .sidebar {
                width: 220px;
            }

            .main-content {
                margin-left: 220px;
                padding: 1rem 1.5rem;
            }
        }

        @@media (max-width: 767px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-right: none;
                border-bottom: 1.5px solid var(--border-color);
                padding: 1rem;
            }

            .main-content {
                margin-left: 0;
                padding: 1.5rem 1rem;
            }
        }

        /* Hide sidebar when not logged in */
        .main-content.full-width {
            margin-left: 0;
            background: #fff;
        }
    </style>
</head>
<body>

    @{
        var isLoggedIn = Context.Session.GetString("UserId") != null;
        var userFullName = Context.Session.GetString("UserFullName");
        var userRole = Context.Session.GetString("UserRole");
    }

    <!-- Fixed Sidebar - Only show if logged in -->
    @if (isLoggedIn)
    {
        <div class="sidebar">
            <a class="sidebar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 20px; height: 20px; display: inline; margin-right: 8px;">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                </svg>
                School Management
            </a>

            <ul class="sidebar-nav">
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                        Home
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="Sections" asp-action="Index">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7" />
                            <rect x="14" y="3" width="7" height="7" />
                            <rect x="14" y="14" width="7" height="7" />
                            <rect x="3" y="14" width="7" height="7" />
                        </svg>
                        Sections
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="Students" asp-action="Index">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                        Students
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a class="sidebar-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                        Privacy
                    </a>
                </li>
            </ul>

            <div class="sidebar-user-section">
                <div class="sidebar-user-info">
                    <div class="sidebar-user-role">@userRole</div>
                    <div class="sidebar-user-name">@userFullName</div>
                </div>
                <a asp-area="" asp-controller="Account" asp-action="Logout" class="sidebar-logout">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    Logout
                </a>
            </div>
        </div>
    }

    <!-- Scrollable Main Content -->
    <div class="main-content @(isLoggedIn ? "" : "full-width")"
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>