@model IEnumerable<mini_project_aspnet.Models.Student>
@{
    ViewData["Title"] = "Students";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />

@Html.AntiForgeryToken()

<div class="page-wrapper">

    <!-- Header -->
    <div class="page-header">
        <div class="page-header-left">
            <h1>Students</h1>
            <p>Manage all students in the system</p>
        </div>
        <div class="page-header-right">
            <a asp-action="Create" class="btn-custom btn-primary-gradient">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                New Student
            </a>
        </div>
    </div>

    <!-- Stats strip -->
    <div class="stats-strip">
        <div class="stat-card accent">
            <div class="stat-label">Total Students</div>
            <div class="stat-num">@Model.Count()</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Active</div>
            <div class="stat-num" style="color: var(--success-color);">@Model.Count(s => s.isActive)</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Inactive</div>
            <div class="stat-num" style="color: var(--danger-color);">@Model.Count(s => !s.isActive)</div>
        </div>
    </div>

    <!-- Table -->
    <div class="card-modern" style="padding: 0; overflow: hidden;">
        <table class="table-modern">
            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>CIN</th>
                    <th>Phone</th>
                    <th>Gender</th>
                    <th>DOB</th>
                    <th>Status</th>
                    <th>Enrollment</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9">
                            <div class="empty-state">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                    <circle cx="12" cy="7" r="4" />
                                </svg>
                                <p>No students found. <a asp-action="Create">Create the first one.</a></p>
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span style="font-weight: 600; color: var(--primary-color);">@item.fullName</span></td>
                        <td><span style="color: var(--text-muted); font-size: 0.9rem;">@item.email</span></td>
                        <td><span class="badge-code">@item.cinNumber</span></td>
                        <td><span style="font-size: 0.9rem;">@item.phoneNumber</span></td>
                        <td>
                            @if (item.gender == Gender.Man)
                            {
                                <span style="color: #3b82f6; font-size: 0.9rem;">👨 Man</span>
                            }
                            else
                            {
                                <span style="color: #ec4899; font-size: 0.9rem;">👩 Woman</span>
                            }
                        </td>
                        <td><span style="color: var(--text-secondary); font-size: 0.82rem;">@item.dateOfBirth.ToString("MMM dd, yyyy")</span></td>
                        <td>
                            @if (item.isActive)
                            {
                                <span class="badge-active yes"><span class="dot"></span>Active</span>
                            }
                            else
                            {
                                <span class="badge-active no"><span class="dot"></span>Inactive</span>
                            }
                        </td>
                        <td><span style="color: var(--text-secondary); font-size: 0.82rem;">@item.enrollmentDate.ToString("MMM dd, yyyy")</span></td>
                        <td>
                            <div class="action-links">
                                <a asp-action="Edit" asp-route-id="@item.id" class="action-btn edit">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                    Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.id" class="action-btn details">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="11" cy="11" r="8" />
                                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                                    </svg>
                                    Details
                                </a>
                                <a href="#" class="action-btn delete" data-bs-toggle="modal" data-bs-target="#deleteModal" 
                                   onclick="setDeleteId('@item.id', '@item.fullName'); return false;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6l-1 14H6L5 6" />
                                        <path d="M10 11v6M14 11v6" />
                                        <path d="M9 6V4h6v2" />
                                    </svg>
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.15);">
            <div class="modal-header" style="border-bottom: 1.5px solid var(--border-color); padding: 1.5rem;">
                <h5 class="modal-title" id="deleteModalLabel" style="font-family: 'Playfair Display', serif; font-size: 1.3rem; color: var(--primary-color);">Delete Student</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <div style="display: flex; align-items: flex-start; gap: 1rem;">
                    <div style="flex-shrink: 0;">
                        <div style="display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; background: var(--danger-bg); border-radius: 12px;">
                            <svg style="width: 24px; height: 24px; color: var(--danger-color);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="3 6 5 6 21 6" />
                                <path d="M19 6l-1 14H6L5 6" />
                                <path d="M10 11v6M14 11v6" />
                                <path d="M9 6V4h6v2" />
                            </svg>
                        </div>
                    </div>
                    <div style="flex: 1;">
                        <p style="margin: 0 0 0.5rem 0; font-weight: 600; color: var(--text-dark);">Are you sure you want to delete this student?</p>
                        <p style="margin: 0; color: var(--text-muted); font-size: 0.9rem;">
                            Student: <strong id="deleteStudentName" style="color: var(--primary-color);"></strong>
                        </p>
                        <p style="margin: 0.5rem 0 0 0; color: var(--text-secondary); font-size: 0.85rem;">This action cannot be undone.</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top: 1.5px solid var(--border-color); padding: 1rem 1.5rem; gap: 0.75rem;">
                <button type="button" class="btn-custom btn-secondary" data-bs-dismiss="modal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 16px; height: 16px;">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                    Cancel
                </button>
                <button type="button" class="btn-custom btn-danger" onclick="confirmDelete()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 16px; height: 16px;">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                    Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let deleteId = '';

    function setDeleteId(id, name) {
        deleteId = id;
        document.getElementById('deleteStudentName').textContent = name;
    }

    function confirmDelete() {
        if (deleteId) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("Delete", "Students")';

            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = token.value;
                form.appendChild(tokenInput);
            }

            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'id';
            input.value = deleteId;
            form.appendChild(input);

            document.body.appendChild(form);
            form.submit();
        }
    }
</script>

<style>
    .btn-danger {
        background: var(--danger-bg);
        color: var(--danger-color);
        border: 1.5px solid #fecaca;
        border-radius: 10px;
        padding: 0.6rem 1.2rem;
        font-size: 0.88rem;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        transition: opacity 0.2s, transform 0.15s;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-danger:hover {
        opacity: 0.88;
        text-decoration: none;
        color: var(--danger-color);
    }

    .btn-secondary {
        background: var(--bg-light);
        color: var(--primary-color);
        border: 1.5px solid var(--border-color);
    }

    .btn-secondary:hover {
        background: #e0e7ff;
        color: var(--primary-color);
        text-decoration: none;
    }

    .btn-custom {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        transition: opacity 0.2s, transform 0.15s;
        cursor: pointer;
        padding: 0.6rem 1.2rem;
    }

    .btn-custom:hover {
        text-decoration: none;
    }

    .modal-content {
        background: #fff;
    }

    .btn-close {
        filter: invert(0.4);
    }
</style>
