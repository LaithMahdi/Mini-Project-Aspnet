@model mini_project_aspnet.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />

<div class="page-wrapper">

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-left">
            <h1>Student Details</h1>
            <p>View complete student information</p>
        </div>
        <div class="page-header-right">
            <a asp-action="Edit" asp-route-id="@Model.id" class="btn-custom btn-primary-gradient">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
                Edit
            </a>
        </div>
    </div>

    <!-- Breadcrumb -->
    <div class="nav-breadcrumb">
        <a asp-action="Index">Students</a>
        <span class="separator">/</span>
        <span>@Model.fullName</span>
    </div>

    <!-- Details Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        
        <!-- Personal Information Card -->
        <div class="card-modern">
            <div style="display: flex; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1.5px solid var(--border-color);">
                <div style="width: 50px; height: 50px; background: var(--info-bg); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 1rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 24px; height: 24px; color: var(--info-color);">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </div>
                <h3 style="margin: 0; font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--primary-color);">Personal Info</h3>
            </div>
            <dl style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <dt style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.3rem;">Full Name</dt>
                    <dd style="margin: 0; color: var(--text-dark); font-weight: 600;">@Model.fullName</dd>
                </div>
                <div>
                    <dt style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.3rem;">Email</dt>
                    <dd style="margin: 0; color: var(--text-muted);">@Model.email</dd>
                </div>
                <div>
                    <dt style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.3rem;">Date of Birth</dt>
                    <dd style="margin: 0; color: var(--text-dark);">@Model.dateOfBirth.ToString("MMMM dd, yyyy")</dd>
                </div>
                <div>
                    <dt style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.3rem;">Gender</dt>
                    <dd style="margin: 0; color: var(--text-dark);">
                        @if (Model.gender == Gender.Man)
                        {
                            <span>👨 Male</span>
                        }
                        else
                        {
                            <span>👩 Female</span>
                        }
                    </dd>
                </div>
            </dl>
        </div>

        <!-- Contact Information Card -->
        <div class="card-modern">
            <div style="display: flex; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1.5px solid var(--border-color);">
                <div style="width: 50px; height: 50px; background: var(--info-bg); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 1rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 24px; height: 24px; color: var(--info-color);">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                </div>
                <h3 style="margin: 0; font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--primary-color);">Contact</h3>
            </div>
            <dl style="display: grid; gap: 1rem;">
                <div>
                    <dt style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.3rem;">Phone</dt>
                    <dd style="margin: 0; color: var(--text-dark);">@Model.phoneNumber</dd>
                </div>
                @if (!string.IsNullOrEmpty(Model.secondPhoneNumber))
                {
                    <div>
                        <dt style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.3rem;">Alternative Phone</dt>
                        <dd style="margin: 0; color: var(--text-dark);">@Model.secondPhoneNumber</dd>
                    </div>
                }
                <div>
                    <dt style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.3rem;">CIN</dt>
                    <dd style="margin: 0; color: var(--text-dark);">@Model.cinNumber</dd>
                </div>
            </dl>
        </div>

        <!-- Academic Information Card -->
        <div class="card-modern">
            <div style="display: flex; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1.5px solid var(--border-color);">
                <div style="width: 50px; height: 50px; background: var(--info-bg); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 1rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 24px; height: 24px; color: var(--info-color);">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                    </svg>
                </div>
                <h3 style="margin: 0; font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--primary-color);">Academic</h3>
            </div>
            <dl style="display: grid; gap: 1rem;">
                <div>
                    <dt style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.3rem;">Enrollment Date</dt>
                    <dd style="margin: 0; color: var(--text-dark);">@Model.enrollmentDate.ToString("MMMM dd, yyyy")</dd>
                </div>
                <div>
                    <dt style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.3rem;">Status</dt>
                    <dd style="margin: 0;">
                        @if (Model.isActive)
                        {
                            <span class="badge-active yes"><span class="dot"></span>Active</span>
                        }
                        else
                        {
                            <span class="badge-active no"><span class="dot"></span>Inactive</span>
                        }
                    </dd>
                </div>
            </dl>
        </div>
    </div>

    <!-- Address Card -->
    @if (!string.IsNullOrEmpty(Model.address))
    {
        <div class="card-modern" style="margin-bottom: 2rem;">
            <div style="display: flex; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1.5px solid var(--border-color);">
                <div style="width: 50px; height: 50px; background: var(--info-bg); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 1rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 24px; height: 24px; color: var(--info-color);">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                        <circle cx="12" cy="10" r="3" />
                    </svg>
                </div>
                <h3 style="margin: 0; font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--primary-color);">Address</h3>
            </div>
            <p style="margin: 0; color: var(--text-dark); line-height: 1.6;">@Model.address</p>
        </div>
    }

    <!-- Metadata -->
    <div class="card-modern" style="background: var(--bg-light);">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; font-size: 0.9rem;">
            <div>
                <span class="text-secondary" style="font-size: 0.75rem;">Student ID</span>
                <div style="color: var(--text-dark); font-weight: 500; font-family: monospace;">@Model.id</div>
            </div>
            <div>
                <span class="text-secondary" style="font-size: 0.75rem;">Created</span>
                <div style="color: var(--text-dark); font-weight: 500;">@Model.createdAt.ToString("MMM dd, yyyy HH:mm")</div>
            </div>
            <div>
                <span class="text-secondary" style="font-size: 0.75rem;">Last Updated</span>
                <div style="color: var(--text-dark); font-weight: 500;">@Model.updatedAt.ToString("MMM dd, yyyy HH:mm")</div>
            </div>
        </div>
    </div>

    <!-- Back Link -->
    <div style="margin-top: 2rem;">
        <a asp-action="Index" class="btn-custom btn-secondary" style="justify-content: center;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to Students
        </a>
    </div>

</div>
