@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - School Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'DM Sans', sans-serif;
            background-color: #f0f2f5;
            display: flex;
        }

        /* Left panel */
        .login-panel-left {
            width: 45%;
            background: linear-gradient(145deg, #0f2b5b 0%, #1a4a9e 60%, #1565c0 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }

            .login-panel-left::before {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                border-radius: 50%;
                background: rgba(255,255,255,0.04);
                top: -100px;
                right: -100px;
            }

            .login-panel-left::after {
                content: '';
                position: absolute;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                background: rgba(255,255,255,0.05);
                bottom: -80px;
                left: -60px;
            }

        .brand-logo {
            width: 64px;
            height: 64px;
            background: rgba(255,255,255,0.15);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255,255,255,0.2);
        }

            .brand-logo svg {
                width: 32px;
                height: 32px;
            }

        .panel-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            color: #fff;
            text-align: center;
            line-height: 1.2;
            margin-bottom: 1rem;
            position: relative;
            z-index: 1;
        }

        .panel-subtitle {
            color: rgba(255,255,255,0.65);
            font-size: 0.95rem;
            text-align: center;
            max-width: 280px;
            line-height: 1.7;
            position: relative;
            z-index: 1;
        }

        .stats-row {
            display: flex;
            gap: 2rem;
            margin-top: 3rem;
            position: relative;
            z-index: 1;
        }

        .stat-item {
            text-align: center;
        }

        .stat-num {
            display: block;
            font-size: 1.6rem;
            font-weight: 600;
            color: #fff;
        }

        .stat-label {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.55);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        /* Right panel */
        .login-panel-right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: #f0f2f5;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: #ffffff;
            border-radius: 20px;
            padding: 2.5rem;
            box-shadow: 0 8px 40px rgba(0,0,0,0.08);
        }

        .login-card-header {
            margin-bottom: 2rem;
        }

            .login-card-header h2 {
                font-family: 'Playfair Display', serif;
                font-size: 1.8rem;
                color: #0f2b5b;
                margin-bottom: 0.25rem;
            }

            .login-card-header p {
                color: #6b7280;
                font-size: 0.9rem;
                margin: 0;
            }

        .form-label {
            font-size: 0.82rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #374151;
            margin-bottom: 0.4rem;
        }

        .form-control {
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            padding: 0.7rem 1rem;
            font-size: 0.95rem;
            font-family: 'DM Sans', sans-serif;
            transition: border-color 0.2s, box-shadow 0.2s;
            background: #fafafa;
        }

            .form-control:focus {
                border-color: #1a4a9e;
                box-shadow: 0 0 0 3px rgba(26,74,158,0.12);
                background: #fff;
                outline: none;
            }

        .input-icon-wrapper {
            position: relative;
        }

            .input-icon-wrapper .input-icon {
                position: absolute;
                right: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #9ca3af;
                pointer-events: none;
            }

            .input-icon-wrapper .form-control {
                padding-right: 2.8rem;
            }

        .btn-login {
            width: 100%;
            padding: 0.8rem;
            background: linear-gradient(135deg, #0f2b5b, #1a4a9e);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 0.95rem;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            letter-spacing: 0.03em;
            transition: opacity 0.2s, transform 0.15s;
            cursor: pointer;
        }

            .btn-login:hover {
                opacity: 0.92;
                transform: translateY(-1px);
            }

            .btn-login:active {
                transform: scale(0.99);
            }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.5rem 0;
            color: #d1d5db;
            font-size: 0.8rem;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #e5e7eb;
            }

        .demo-box {
            background: #f8faff;
            border: 1px dashed #c7d8f5;
            border-radius: 10px;
            padding: 0.9rem 1.1rem;
            font-size: 0.82rem;
            color: #374151;
        }

            .demo-box strong {
                color: #1a4a9e;
            }

            .demo-box .demo-title {
                font-size: 0.72rem;
                text-transform: uppercase;
                letter-spacing: 0.07em;
                color: #9ca3af;
                font-weight: 600;
                margin-bottom: 0.4rem;
            }

        @@media (max-width: 768px) {
            .login-panel-left {
                display: none;
            }

            .login-panel-right {
                background: #fff;
            }

            .login-card {
                box-shadow: none;
                padding: 2rem 1.5rem;
            }
        }
    </style>
</head>
<body>

    <!-- Left decorative panel -->
    <div class="login-panel-left">
        <div class="brand-logo">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 3L4 9v6c0 7.18 5.16 13.9 12 15.93C22.84 28.9 28 22.18 28 15V9L16 3z" fill="rgba(255,255,255,0.9)" />
                <path d="M12 16l3 3 6-6" stroke="#1a4a9e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
        <h1 class="panel-title">School<br />Management<br />System</h1>
        <p class="panel-subtitle">A unified platform for managing students, teachers, sections, and academic workflows.</p>
        <div class="stats-row">
            <div class="stat-item">
                <span class="stat-num">500+</span>
                <span class="stat-label">Students</span>
            </div>
            <div class="stat-item">
                <span class="stat-num">40+</span>
                <span class="stat-label">Teachers</span>
            </div>
            <div class="stat-item">
                <span class="stat-num">20+</span>
                <span class="stat-label">Sections</span>
            </div>
        </div>
    </div>

    <!-- Right login panel -->
    <div class="login-panel-right">
        <div class="login-card">
            <div class="login-card-header">
                <h2>Welcome back</h2>
                <p>Sign in to your administrator account</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert" style="font-size:0.88rem;">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    }
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form method="post" asp-action="Login" asp-controller="Account">
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-icon-wrapper">
                        <input type="email" name="email" class="form-control" placeholder="admin@school.com" required value="admin@itbs.com" />
                        <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                            <polyline points="22,6 12,13 2,6" />
                        </svg>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="input-icon-wrapper">
                        <input type="password" name="password" class="form-control" placeholder="••••••••••" required value="123456789" />
                        <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </div>
                </div>

                <button type="submit" class="btn-login">Sign In</button>
            </form>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>