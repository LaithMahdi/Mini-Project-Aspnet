@model school.Models.Classe

@{
    ViewData["Title"] = "Delete Class";
}

<section class="class-delete-page">
    <div class="class-delete-header">
        <div>
            <h1>Delete Class</h1>
            <p class="class-delete-subtitle">This action permanently removes the class from the system.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to Classes</a>
    </div>

    <div class="class-delete-shell">
        <div class="class-delete-warning">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div>
                <strong>Confirm deletion</strong>
                <p>Deleting this class may affect class-subject and scheduling relationships.</p>
            </div>
        </div>

        <dl class="class-delete-details">
            <div><dt>Name</dt><dd>@Model.Name</dd></div>
            <div><dt>Level</dt><dd>@Model.Level</dd></div>
            <div><dt>Academic Year</dt><dd>@Model.AcademicYear</dd></div>
            <div><dt>Section</dt><dd>@(Model.Section?.Name ?? "-")</dd></div>
            <div><dt>Teacher</dt><dd>@(Model.ReferentTeacher?.User?.FullName ?? "-")</dd></div>
            <div><dt>Capacity</dt><dd>@Model.MaxCapacity</dd></div>
        </dl>

        <form asp-action="Delete" class="class-delete-actions">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete Permanently</button>
            <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
        </form>
    </div>
</section>
