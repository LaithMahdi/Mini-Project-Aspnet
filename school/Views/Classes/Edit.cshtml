@model school.Models.Classe
@using school.Models
@{
    var assignments = ViewData["ClassSubjectAssignments"] as List<ClassSubject> ?? new List<ClassSubject>();
}

@{
    ViewData["Title"] = "Update Class";
}

<section class="class-form-page">
    <div class="class-form-header">
        <div>
            <h1>Update Class</h1>
            <p class="class-form-subtitle">Update class structure, links, and capacity settings.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to Classes</a>
    </div>

    <div class="class-form-shell">
        <form asp-action="Edit" class="class-form-grid">
            <div asp-validation-summary="ModelOnly" class="class-validation"></div>
            <input type="hidden" asp-for="Id" />

            <div class="class-form-fields">
                <div class="form-group">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Level" class="control-label"></label>
                    <input asp-for="Level" class="form-control" />
                    <span asp-validation-for="Level" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Filiere" class="control-label"></label>
                    <input asp-for="Filiere" class="form-control" />
                    <span asp-validation-for="Filiere" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MaxCapacity" class="control-label"></label>
                    <input asp-for="MaxCapacity" class="form-control" />
                    <span asp-validation-for="MaxCapacity" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AcademicYear" class="control-label"></label>
                    <input asp-for="AcademicYear" class="form-control" />
                    <span asp-validation-for="AcademicYear" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SectionId" class="control-label">Section</label>
                    <select asp-for="SectionId" class="form-control" asp-items="ViewBag.SectionId">
                        <option value="">-- Select Section --</option>
                    </select>
                    <span asp-validation-for="SectionId" class="text-danger"></span>
                </div>

                <div class="form-group full-col">
                    <label asp-for="ReferentTeacherId" class="control-label">Referent Teacher</label>
                    <select asp-for="ReferentTeacherId" class="form-control" asp-items="ViewBag.ReferentTeacherId">
                        <option value="">-- Select Teacher --</option>
                    </select>
                    <span asp-validation-for="ReferentTeacherId" class="text-danger"></span>
                </div>

                <div class="form-group full-col class-check-wrap">
                    <label class="form-check class-check-control">
                        <input class="form-check-input" asp-for="IsArchived" />
                        <span>@Html.DisplayNameFor(model => model.IsArchived)</span>
                    </label>
                </div>
            </div>

            <div class="class-form-meta">
                <span>Created: @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                <span>Last Update: @Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</span>
            </div>

            <div class="class-form-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
            </div>
        </form>
    </div>

    <div class="class-form-shell">
        <h3>Subject Assignments</h3>

        @if (TempData["ClassEditError"] != null)
        {
            <div class="class-validation" role="alert">@TempData["ClassEditError"]</div>
        }

        <form asp-action="AddSubjectAssignment" method="post" class="class-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="class-form-fields">
                <div class="form-group">
                    <label class="control-label">Subject</label>
                    <select name="subjectId" class="form-control" asp-items="ViewBag.SubjectOptions"></select>
                </div>

                <div class="form-group">
                    <label class="control-label">Teacher</label>
                    <select name="teacherId" class="form-control" asp-items="ViewBag.TeacherOptions">
                        <option value="">-- Select Teacher --</option>
                    </select>
                </div>
            </div>

            <div class="class-form-actions">
                <button type="submit" class="btn btn-primary">Add / Update Assignment</button>
            </div>
        </form>

        @if (assignments.Any())
        {
            <div class="classes-table-wrap mt-3">
                <table class="classes-table">
                    <thead>
                        <tr>
                            <th>Subject</th>
                            <th>Teacher</th>
                            <th>Assigned At</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var assignment in assignments)
                        {
                            <tr>
                                <td>@assignment.Subject.Name (@assignment.Subject.Code)</td>
                                <td>@(assignment.Teacher?.User?.FullName ?? "-")</td>
                                <td>@assignment.AssignedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <form asp-action="RemoveSubjectAssignment" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <input type="hidden" name="classSubjectId" value="@assignment.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="classes-empty-state mt-3">No subject assignment yet for this class.</div>
        }
    </div>

    <div class="class-form-shell">
        <h3>Student List Assignment</h3>
        <p class="class-form-subtitle">Select active students to affect to this class. Selected students become members of this class.</p>

        <form asp-action="UpdateStudentAssignments" method="post" class="class-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="form-group">
                <label class="control-label">Students</label>
                <select name="studentIds" class="form-control" asp-items="ViewBag.ClassStudentOptions" multiple size="12"></select>
                <small class="text-muted">Tip: hold Ctrl (or Cmd) to select multiple students.</small>
            </div>

            <div class="class-form-actions">
                <button type="submit" class="btn btn-primary">Update Student List</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
