@model school.ViewModels.UserCreateViewModel

@{
    ViewData["Title"] = "Create New User";
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900">Create New User</h1>
    <p class="text-slate-600 mt-2">Add a new student or teacher to the school management system</p>
</div>

<div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
    <form asp-action="Create" method="post" class="space-y-6">
        <!-- Validation Summary -->
        <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 rounded-lg p-4 text-red-700 hidden" id="validationSummary"></div>

        <!-- Row 1: Full Name & Role -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="FullName" class="block text-sm font-semibold text-slate-700 mb-2">Full Name <span class="text-red-500">*</span></label>
                <input asp-for="FullName" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" placeholder="Enter full name" />
                <span asp-validation-for="FullName" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Role" class="block text-sm font-semibold text-slate-700 mb-2">User Type <span class="text-red-500">*</span></label>
                <select asp-for="Role" id="Role" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition bg-white cursor-pointer" asp-items="ViewBag.Roles">
                </select>
                <span asp-validation-for="Role" class="text-red-500 text-sm mt-1 block"></span>
            </div>
        </div>

        <!-- Row 2: Gender & Active Status -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="Gender" class="block text-sm font-semibold text-slate-700 mb-2">Gender <span class="text-red-500">*</span></label>
                <select asp-for="Gender" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition bg-white cursor-pointer" asp-items="ViewBag.Genders">
                    <option value="">-- Select Gender --</option>
                </select>
                <span asp-validation-for="Gender" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div class="flex items-end">
                <div class="flex items-center space-x-3 bg-slate-50 px-4 py-3 rounded-lg w-full">
                    <input type="checkbox" asp-for="IsActive" class="w-5 h-5 text-indigo-600 rounded focus:ring-2 focus:ring-indigo-500 cursor-pointer" checked />
                    <label asp-for="IsActive" class="font-medium text-slate-700 cursor-pointer">Active User</label>
                </div>
            </div>
        </div>

        <!-- Divider -->
        <div class="border-t border-slate-200"></div>

        <!-- Account Section -->
        <div>
            <h3 class="text-lg font-semibold text-slate-900 mb-4">Account Information</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="UserName" class="block text-sm font-semibold text-slate-700 mb-2">Username <span class="text-red-500">*</span></label>
                    <input asp-for="UserName" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" placeholder="Enter username" />
                    <span asp-validation-for="UserName" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-semibold text-slate-700 mb-2">Password <span class="text-red-500">*</span></label>
                    <input asp-for="Password" type="password" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" placeholder="Enter password" />
                    <span asp-validation-for="Password" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-slate-700 mb-2">Email</label>
                    <input asp-for="Email" type="email" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" placeholder="Enter email" />
                    <span asp-validation-for="Email" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="PhoneNumber" class="block text-sm font-semibold text-slate-700 mb-2">Phone Number</label>
                    <input asp-for="PhoneNumber" type="tel" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" placeholder="Enter phone number" />
                    <span asp-validation-for="PhoneNumber" class="text-red-500 text-sm mt-1 block"></span>
                </div>
            </div>
        </div>

        <!-- Teacher Information Section -->
        <div id="teacherFields" class="hidden p-6 bg-gradient-to-br from-blue-50 to-blue-50 rounded-lg border border-blue-200">
            <h3 class="text-lg font-semibold text-blue-900 mb-4 flex items-center">
                Teacher Information
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Specialization" class="block text-sm font-semibold text-blue-900 mb-2">Specialization</label>
                    <input asp-for="Specialization" class="w-full px-4 py-2 border border-blue-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" placeholder="e.g., Mathematics, Physics" />
                    <span asp-validation-for="Specialization" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="HireDate" class="block text-sm font-semibold text-blue-900 mb-2">Hire Date</label>
                    <input asp-for="HireDate" type="date" class="w-full px-4 py-2 border border-blue-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                    <span asp-validation-for="HireDate" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Salary" class="block text-sm font-semibold text-blue-900 mb-2">Salary</label>
                    <input asp-for="Salary" type="number" step="0.01" class="w-full px-4 py-2 border border-blue-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" placeholder="0.00" />
                    <span asp-validation-for="Salary" class="text-red-500 text-sm mt-1 block"></span>
                </div>
            </div>
        </div>

        <!-- Student Information Section -->
        <div id="studentFields" class="p-6 bg-gradient-to-br from-green-50 to-green-50 rounded-lg border border-green-200">
            <h3 class="text-lg font-semibold text-green-900 mb-4 flex items-center">
                Student Information
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="DateOfBirth" class="block text-sm font-semibold text-green-900 mb-2">Date of Birth</label>
                    <input asp-for="DateOfBirth" type="date" class="w-full px-4 py-2 border border-green-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" />
                    <span asp-validation-for="DateOfBirth" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="CinNumber" class="block text-sm font-semibold text-green-900 mb-2">ID Number</label>
                    <input asp-for="CinNumber" class="w-full px-4 py-2 border border-green-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" placeholder="e.g., AB123456" />
                    <span asp-validation-for="CinNumber" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="SecondPhoneNumber" class="block text-sm font-semibold text-green-900 mb-2">Secondary Phone</label>
                    <input asp-for="SecondPhoneNumber" type="tel" class="w-full px-4 py-2 border border-green-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" placeholder="Parent/Guardian phone" />
                    <span asp-validation-for="SecondPhoneNumber" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="EnrollmentDate" class="block text-sm font-semibold text-green-900 mb-2">Enrollment Date</label>
                    <input asp-for="EnrollmentDate" type="date" class="w-full px-4 py-2 border border-green-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" />
                    <span asp-validation-for="EnrollmentDate" class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Address" class="block text-sm font-semibold text-green-900 mb-2">Address</label>
                    <input asp-for="Address" class="w-full px-4 py-2 border border-green-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" placeholder="Street address, city, zip code" />
                    <span asp-validation-for="Address" class="text-red-500 text-sm mt-1 block"></span>
                </div>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="flex gap-4 pt-6 border-t border-slate-200">
            <button type="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-lg transition duration-200 shadow-sm hover:shadow-md">
                Create User
            </button>
            <a asp-action="Index" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold py-3 rounded-lg transition duration-200 text-center">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const roleSelect = document.getElementById('Role');
            const teacherFields = document.getElementById('teacherFields');
            const studentFields = document.getElementById('studentFields');

            function toggleRoleSections() {
                const selectedText = roleSelect.options[roleSelect.selectedIndex]?.text;
                if (selectedText === 'Teacher') {
                    teacherFields.classList.remove('hidden');
                    studentFields.classList.add('hidden');
                } else if (selectedText === 'Student') {
                    teacherFields.classList.add('hidden');
                    studentFields.classList.remove('hidden');
                }
            }

            roleSelect.addEventListener('change', toggleRoleSections);
            toggleRoleSections();
        })();
    </script>
    }