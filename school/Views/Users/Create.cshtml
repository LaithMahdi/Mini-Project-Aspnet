@model school.ViewModels.UserCreateViewModel

@{
    ViewData["Title"] = "Create New User";
}

<section class="user-form-page">
    <div class="user-form-header">
        <div>
            <h1>Create New User</h1>
            <p class="user-form-subtitle">Add a student or teacher account with profile and contact details.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to Users</a>
    </div>

    <div class="user-form-shell">
        <form asp-action="Create" method="post" class="user-form-grid">
            <div asp-validation-summary="ModelOnly" class="user-validation"></div>

            <div class="user-form-section">
                <h3>Basic Information</h3>
                <div class="user-form-fields two-cols">
                    <div class="form-group">
                        <label asp-for="FullName" class="control-label">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="Enter full name" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Role" class="control-label">User Type</label>
                        <select asp-for="Role" id="Role" class="form-control" asp-items="ViewBag.Roles"></select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Gender" class="control-label">Gender</label>
                        <select asp-for="Gender" class="form-control" asp-items="ViewBag.Genders">
                            <option value="">-- Select Gender --</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>

                    <div class="form-group user-check-wrap">
                        <label class="form-check user-check-control">
                            <input type="checkbox" asp-for="IsActive" class="form-check-input" />
                            <span>Active User</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="user-form-section">
                <h3>Account Information</h3>
                <div class="user-form-fields two-cols">
                    <div class="form-group">
                        <label asp-for="UserName" class="control-label">Username</label>
                        <input asp-for="UserName" class="form-control" placeholder="Enter username" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password" class="control-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email" class="control-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Enter email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PhoneNumber" class="control-label">Phone Number</label>
                        <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="Enter phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div id="teacherFields" class="user-form-section user-form-section-teacher u-hidden">
                <h3>Teacher Information</h3>
                <div class="user-form-fields two-cols">
                    <div class="form-group">
                        <label asp-for="Specialization" class="control-label">Specialization</label>
                        <input asp-for="Specialization" class="form-control" placeholder="e.g., Mathematics, Physics" />
                        <span asp-validation-for="Specialization" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="HireDate" class="control-label">Hire Date</label>
                        <input asp-for="HireDate" type="date" class="form-control" />
                        <span asp-validation-for="HireDate" class="text-danger"></span>
                    </div>

                    <div class="form-group full-col">
                        <label asp-for="Salary" class="control-label">Salary</label>
                        <input asp-for="Salary" type="number" step="0.01" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="Salary" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div id="studentFields" class="user-form-section user-form-section-student">
                <h3>Student Information</h3>
                <div class="user-form-fields two-cols">
                    <div class="form-group">
                        <label asp-for="DateOfBirth" class="control-label">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="CinNumber" class="control-label">ID Number</label>
                        <input asp-for="CinNumber" class="form-control" placeholder="e.g., AB123456" />
                        <span asp-validation-for="CinNumber" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="SecondPhoneNumber" class="control-label">Secondary Phone</label>
                        <input asp-for="SecondPhoneNumber" type="tel" class="form-control" placeholder="Parent/Guardian phone" />
                        <span asp-validation-for="SecondPhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="EnrollmentDate" class="control-label">Enrollment Date</label>
                        <input asp-for="EnrollmentDate" type="date" class="form-control" />
                        <span asp-validation-for="EnrollmentDate" class="text-danger"></span>
                    </div>

                    <div class="form-group full-col">
                        <label asp-for="Address" class="control-label">Address</label>
                        <input asp-for="Address" class="form-control" placeholder="Street address, city, zip code" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="user-form-actions">
                <button type="submit" class="btn btn-primary">Create User</button>
                <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const roleSelect = document.getElementById('Role');
            const teacherFields = document.getElementById('teacherFields');
            const studentFields = document.getElementById('studentFields');

            function toggleRoleSections() {
                const selectedText = roleSelect.options[roleSelect.selectedIndex]?.text;
                if (selectedText === 'Teacher') {
                    teacherFields.classList.remove('u-hidden');
                    studentFields.classList.add('u-hidden');
                } else if (selectedText === 'Student') {
                    teacherFields.classList.add('u-hidden');
                    studentFields.classList.remove('u-hidden');
                }
            }

            roleSelect.addEventListener('change', toggleRoleSections);
            toggleRoleSections();
        })();
    </script>
}