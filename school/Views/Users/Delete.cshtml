@model school.Models.User

@{
    ViewData["Title"] = "Delete User";
}

<section class="user-delete-page">
    <div class="user-delete-header">
        <div>
            <h1>Delete User</h1>
            <p class="user-delete-subtitle">This action permanently removes the account and cannot be undone.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to Users</a>
    </div>

    <div class="user-delete-shell">
        <div class="user-delete-warning">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div>
                <strong>Confirm deletion</strong>
                <p>You are about to delete this user from the system. Please verify the details below.</p>
            </div>
        </div>

        <div class="user-delete-summary">
            <div class="user-delete-avatar">@((Model.FullName?.Length ?? 0) > 0 ? Model.FullName![0].ToString().ToUpper() : "U")</div>
            <div>
                <div class="user-delete-name">@Model.FullName</div>
                <div class="user-delete-meta-row">
                    <span class="users-role-badge @(Model.Role == school.Models.Role.Student ? "users-role-student" : Model.Role == school.Models.Role.Teacher ? "users-role-teacher" : "users-role-admin")">@Model.Role</span>
                    @if (Model.IsActive)
                    {
                        <span class="users-status users-status-active">Active</span>
                    }
                    else
                    {
                        <span class="users-status users-status-inactive">Inactive</span>
                    }
                </div>
            </div>
        </div>

        <dl class="user-delete-details">
            <div>
                <dt>Username</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.UserName) ? "-" : Model.UserName)</dd>
            </div>
            <div>
                <dt>Email</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</dd>
            </div>
            <div>
                <dt>User ID</dt>
                <dd class="detail-code">@Model.Id</dd>
            </div>
        </dl>

        <form asp-action="Delete" class="user-delete-actions">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete Permanently</button>
            <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
        </form>
    </div>
</section>
