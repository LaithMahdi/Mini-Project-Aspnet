@model school.Models.Section

@{
    ViewData["Title"] = "Delete Section";
}

<section class="section-delete-page">
    <div class="section-delete-header">
        <div>
            <h1>Delete Section</h1>
            <p class="section-delete-subtitle">This action permanently removes the section from the system.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to Sections</a>
    </div>

    <div class="section-delete-shell">
        <div class="section-delete-warning">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div>
                <strong>Confirm deletion</strong>
                <p>Deleting this section may affect linked classes and scheduling records.</p>
            </div>
        </div>

        <dl class="section-delete-details">
            <div>
                <dt>Name</dt>
                <dd>@Model.Name</dd>
            </div>
            <div>
                <dt>Code</dt>
                <dd>@Model.Code</dd>
            </div>
            <div class="full-col">
                <dt>Description</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</dd>
            </div>
            <div>
                <dt>Created</dt>
                <dd>@Model.CreatedAt.ToString("yyyy-MM-dd")</dd>
            </div>
            <div>
                <dt>Updated</dt>
                <dd>@Model.UpdatedAt.ToString("yyyy-MM-dd")</dd>
            </div>
        </dl>

        <form asp-action="Delete" class="section-delete-actions">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete Permanently</button>
            <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
        </form>
    </div>
</section>
