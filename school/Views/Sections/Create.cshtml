@model school.Models.Section

@{
    ViewData["Title"] = "Create Section";
}

<section class="section-form-page">
    <div class="section-form-header">
        <div>
            <h1>Create Section</h1>
            <p class="section-form-subtitle">Create a new department section and define its code and description.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to Sections</a>
    </div>

    <div class="section-form-shell">
        <form asp-action="Create" class="section-form-grid">
            <div asp-validation-summary="ModelOnly" class="section-validation"></div>

            <div class="section-form-fields">
                <div class="form-group">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., Computer Science" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Code" class="control-label"></label>
                    <input asp-for="Code" class="form-control" placeholder="e.g., CS" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                <div class="form-group full-col">
                    <label asp-for="Description" class="control-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Short section description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="section-form-actions">
                <button type="submit" class="btn btn-primary">Create Section</button>
                <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
