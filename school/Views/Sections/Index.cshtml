@model IEnumerable<school.Models.Section>

@{
    ViewData["Title"] = "Sections";

    var search = ViewBag.Search as string;
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 15;
    var filteredTotal = ViewBag.FilteredTotal as int? ?? 0;
    var startItem = filteredTotal == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    var endItem = filteredTotal == 0 ? 0 : Math.Min(currentPage * pageSize, filteredTotal);
    var pageWindowStart = Math.Max(1, currentPage - 1);
    var pageWindowEnd = Math.Min(totalPages, currentPage + 1);
}

<section class="sections-page">
    <div class="sections-header">
        <div>
            <h1>Sections Management</h1>
            <p class="sections-subtitle">Manage academic sections and departments.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">+ Create New Section</a>
    </div>

    <form asp-action="Index" method="get" class="sections-filter-bar">
        <div class="sections-filter-group sections-filter-search">
            <label for="search">Search</label>
            <input id="search" name="search" value="@search" class="form-control" placeholder="Name, code, description" />
        </div>

        <div class="sections-filter-actions">
            <button type="submit" class="btn btn-primary">Apply</button>
            <a asp-action="Index" class="btn btn-outline-light">Clear</a>
        </div>
    </form>

    <div class="sections-table-wrap">
        <table class="sections-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Description</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>
                            <span class="sections-code-badge">@item.Code</span>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>
                        <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>@item.UpdatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="sections-actions-cell">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="sections-action sections-action-edit">Edit</a>
                            <button type="button"
                                    class="sections-action sections-action-delete js-open-section-delete-dialog"
                                    data-section-id="@item.Id"
                                    data-section-name="@item.Name">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="sections-pagination-wrap">
        <div class="sections-pagination-summary">
            Showing @startItem-@endItem of @filteredTotal sections
        </div>

        @if (totalPages > 1)
        {
            <nav class="sections-pagination" aria-label="Sections pagination">
                @if (currentPage > 1)
                {
                    <a asp-action="Index"
                       asp-route-page="@(currentPage - 1)"
                       asp-route-search="@search"
                       class="sections-page-link">Previous</a>
                }
                else
                {
                    <span class="sections-page-link sections-page-link-disabled">Previous</span>
                }

                @if (pageWindowStart > 1)
                {
                    <a asp-action="Index"
                       asp-route-page="1"
                       asp-route-search="@search"
                       class="sections-page-link">1</a>

                    @if (pageWindowStart > 2)
                    {
                        <span class="sections-page-ellipsis">...</span>
                    }
                }

                @for (var i = pageWindowStart; i <= pageWindowEnd; i++)
                {
                    if (i == currentPage)
                    {
                        <span class="sections-page-link sections-page-link-active">@i</span>
                    }
                    else
                    {
                        <a asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@search"
                           class="sections-page-link">@i</a>
                    }
                }

                @if (pageWindowEnd < totalPages)
                {
                    @if (pageWindowEnd < totalPages - 1)
                    {
                        <span class="sections-page-ellipsis">...</span>
                    }

                    <a asp-action="Index"
                       asp-route-page="@totalPages"
                       asp-route-search="@search"
                       class="sections-page-link">@totalPages</a>
                }

                @if (currentPage < totalPages)
                {
                    <a asp-action="Index"
                       asp-route-page="@(currentPage + 1)"
                       asp-route-search="@search"
                       class="sections-page-link">Next</a>
                }
                else
                {
                    <span class="sections-page-link sections-page-link-disabled">Next</span>
                }
            </nav>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="sections-empty-state" role="alert">
            No sections found. <a asp-action="Create">Create the first section</a>
        </div>
    }
</section>

<dialog id="deleteSectionDialog" class="sections-delete-dialog">
    <div class="sections-delete-dialog-card">
        <div class="sections-delete-dialog-head">
            <h3>Delete Section</h3>
            <button type="button" class="sections-delete-dialog-close" id="closeSectionDeleteDialogBtn" aria-label="Close">&times;</button>
        </div>

        <p class="sections-delete-dialog-text">
            Are you sure you want to delete <strong id="deleteSectionNameText">this section</strong>? This action cannot be undone.
        </p>

        <form asp-action="Delete" method="post" class="sections-delete-dialog-actions">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteSectionIdInput" name="id" />
            <button type="submit" class="btn btn-danger">Delete Permanently</button>
            <button type="button" class="btn btn-outline-light" id="cancelSectionDeleteDialogBtn">Cancel</button>
        </form>
    </div>
</dialog>

@section Scripts {
    <script>
        (function () {
            const dialog = document.getElementById('deleteSectionDialog');
            const sectionIdInput = document.getElementById('deleteSectionIdInput');
            const sectionNameText = document.getElementById('deleteSectionNameText');
            const cancelBtn = document.getElementById('cancelSectionDeleteDialogBtn');
            const closeBtn = document.getElementById('closeSectionDeleteDialogBtn');
            const openBtns = document.querySelectorAll('.js-open-section-delete-dialog');

            if (!dialog || !sectionIdInput || !sectionNameText || !cancelBtn || !closeBtn || !openBtns.length) {
                return;
            }

            openBtns.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const sectionId = btn.getAttribute('data-section-id');
                    const sectionName = btn.getAttribute('data-section-name') || 'this section';

                    sectionIdInput.value = sectionId || '';
                    sectionNameText.textContent = sectionName;
                    dialog.showModal();
                });
            });

            cancelBtn.addEventListener('click', function () {
                dialog.close();
            });

            closeBtn.addEventListener('click', function () {
                dialog.close();
            });
        })();
    </script>
}
