@model school.Models.Subject

@{
    ViewData["Title"] = "Delete Subject";
}

<section class="subject-delete-page">
    <div class="subject-delete-header">
        <div>
            <h1>Delete Subject</h1>
            <p class="subject-delete-subtitle">Review this subject before permanent deletion.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to List</a>
    </div>

    <div class="subject-delete-shell">
        <div class="subject-delete-warning" role="alert">
            <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
            <div>
                <strong>This action is permanent.</strong>
                <p>The subject and its linked planning references may be impacted.</p>
            </div>
        </div>

        <dl class="subject-delete-details">
            <div>
                <dt>Name</dt>
                <dd>@Model.Name</dd>
            </div>
            <div>
                <dt>Code</dt>
                <dd>@Model.Code</dd>
            </div>
            <div>
                <dt>Type</dt>
                <dd>@Model.Type</dd>
            </div>
            <div>
                <dt>Status</dt>
                <dd>@(Model.IsActive ? "Active" : "Inactive")</dd>
            </div>
            <div>
                <dt>Coefficient</dt>
                <dd>@Model.Coefficient</dd>
            </div>
            <div>
                <dt>Hours/Week</dt>
                <dd>@Model.HoursPerWeek h</dd>
            </div>
        </dl>

        <form asp-action="Delete" class="subject-delete-actions">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete Subject</button>
            <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
        </form>
    </div>
</section>
