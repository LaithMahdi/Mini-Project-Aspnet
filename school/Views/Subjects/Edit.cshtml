@model school.Models.Subject

@{
    ViewData["Title"] = "Edit Subject";

    var typeOptions = ViewBag.SubjectTypeOptions as SelectList;
}

<section class="subject-form-page">
    <div class="subject-form-header">
        <div>
            <h1>Edit Subject</h1>
            <p class="subject-form-subtitle">Update the subject details and activation status.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to List</a>
    </div>

    <div class="subject-form-shell">
        <form asp-action="Edit" class="subject-form-grid">
            <div asp-validation-summary="ModelOnly" class="subject-validation"></div>
            <input type="hidden" asp-for="Id" />

            <div class="subject-form-fields">
                <div class="form-group">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Code" class="control-label"></label>
                    <input asp-for="Code" class="form-control" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Coefficient" class="control-label"></label>
                    <input asp-for="Coefficient" class="form-control" />
                    <span asp-validation-for="Coefficient" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="HoursPerWeek" class="control-label"></label>
                    <input asp-for="HoursPerWeek" class="form-control" />
                    <span asp-validation-for="HoursPerWeek" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Type" class="control-label"></label>
                    <select asp-for="Type" class="form-control" asp-items="typeOptions"></select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>

                <div class="form-group subject-check-wrap">
                    <label class="subject-check-control">
                        <input class="form-check-input" asp-for="IsActive" />
                        <span>Subject is active</span>
                    </label>
                </div>
            </div>

            <div class="subject-form-meta">
                <span><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                <span><strong>Updated:</strong> @Model.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
            </div>

            <div class="subject-form-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
