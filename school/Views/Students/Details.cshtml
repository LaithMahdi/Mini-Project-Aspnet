@model school.Models.Student

@{
    ViewData["Title"] = "Student Details";
    var isTeacher = ViewBag.IsTeacher as bool? ?? false;
}

<section class="user-details-page">
    <div class="user-details-header">
        <div>
            <h1>Student Details</h1>
            <p class="user-details-subtitle">Profile, class assignment and contact information.</p>
        </div>
        <div class="user-details-actions">
            @if (!isTeacher)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Student</a>
            }
            <a asp-action="Index" class="btn btn-outline-light">Back to Students</a>
        </div>
    </div>

    <div class="user-details-shell">
        <div class="user-details-summary-card">
            <span class="user-avatar-chip">@((Model.User?.FullName?.FirstOrDefault().ToString() ?? "S").ToUpper())</span>
            <div>
                <div class="user-details-name">@(Model.User?.FullName ?? "-")</div>
                <div class="user-details-meta-row">
                    <span class="users-role-badge users-role-student">Student</span>
                    @if (Model.IsActive)
                    {
                        <span class="users-status users-status-active">Active</span>
                    }
                    else
                    {
                        <span class="users-status users-status-inactive">Inactive</span>
                    }
                </div>
            </div>
        </div>

        <div class="user-details-grid two-cols">
            <section class="user-details-card">
                <h3>Academic</h3>
                <dl class="user-details-list two-cols">
                    <div><dt>Class</dt><dd>@(Model.Class?.Name ?? "-")</dd></div>
                    <div><dt>Enrollment Date</dt><dd>@Model.EnrollmentDate.ToString("yyyy-MM-dd")</dd></div>
                    <div><dt>Date of Birth</dt><dd>@(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "-")</dd></div>
                    <div><dt>Gender</dt><dd>@(Model.Gender?.ToString() ?? "-")</dd></div>
                    <div><dt>CIN Number</dt><dd>@(string.IsNullOrWhiteSpace(Model.CinNumber) ? "-" : Model.CinNumber)</dd></div>
                </dl>
            </section>

            <section class="user-details-card role-card-student">
                <h3>Account & Contact</h3>
                <dl class="user-details-list two-cols">
                    <div><dt>Username</dt><dd>@(Model.User?.UserName ?? "-")</dd></div>
                    <div><dt>Email</dt><dd>@(Model.User?.Email ?? "-")</dd></div>
                    <div><dt>Phone</dt><dd>@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "-" : Model.PhoneNumber)</dd></div>
                    <div><dt>Second Phone</dt><dd>@(string.IsNullOrWhiteSpace(Model.SecondPhoneNumber) ? "-" : Model.SecondPhoneNumber)</dd></div>
                    <div class="full-col"><dt>Address</dt><dd>@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</dd></div>
                    <div class="full-col"><dt>User Id</dt><dd class="detail-code">@Model.UserId</dd></div>
                </dl>
            </section>
        </div>
    </div>
</section>
