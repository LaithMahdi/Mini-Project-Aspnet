@model school.Models.Session

@{
    ViewData["Title"] = "Delete Session";
}

<section class="session-delete-page">
    <div class="session-delete-header">
        <div>
            <h1>Delete Session</h1>
            <p class="session-delete-subtitle">Review session details before permanent deletion.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to List</a>
    </div>

    <div class="session-delete-shell">
        <div class="session-delete-warning" role="alert">
            <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
            <div>
                <strong>This action is permanent.</strong>
                <p>Deleting a session may affect planning history and references.</p>
            </div>
        </div>

        <dl class="session-delete-details">
            <div>
                <dt>Date</dt>
                <dd>@Model.SessionDate.ToString("dd/MM/yyyy")</dd>
            </div>
            <div>
                <dt>Time</dt>
                <dd>@Model.StartTime.ToString("HH:mm") - @Model.EndTime.ToString("HH:mm")</dd>
            </div>
            <div>
                <dt>Status</dt>
                <dd>@Model.Status</dd>
            </div>
            <div>
                <dt>Teacher</dt>
                <dd>@(Model.Teacher?.User?.FullName ?? "-")</dd>
            </div>
            <div>
                <dt>Subject</dt>
                <dd>@(Model.Subject != null ? Model.Subject.Name + " (" + Model.Subject.Code + ")" : "-")</dd>
            </div>
            <div>
                <dt>Room</dt>
                <dd>@(Model.Room?.Name ?? "-")</dd>
            </div>
        </dl>

        <form asp-action="Delete" class="session-delete-actions">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete Session</button>
            <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
        </form>
    </div>
</section>
