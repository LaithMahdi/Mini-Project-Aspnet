@model school.Models.Session

@{
    ViewData["Title"] = "Session Details";
    var isTeacher = ViewBag.IsTeacher as bool? ?? false;
}

<section class="session-details-page">
    <div class="session-details-header">
        <div>
            <h1>Session Details</h1>
            <p class="session-details-subtitle">Review schedule, status, and assigned resources.</p>
        </div>
        <div class="session-details-actions">
            @if (!isTeacher)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Session</a>
            }
            <a asp-action="Index" class="btn btn-outline-light">Back to List</a>
        </div>
    </div>

    <div class="session-details-shell">
        <div class="session-details-summary-card">
            <span class="session-chip">@Model.SessionDate.ToString("dd/MM/yyyy") | @Model.StartTime.ToString("HH:mm") - @Model.EndTime.ToString("HH:mm")</span>
            <div class="session-details-meta-row">
                <span class="sessions-status sessions-status-@Model.Status.ToString().ToLower()">@Model.Status</span>
                <span class="sessions-status @(Model.IsActive ? "sessions-status-active-flag" : "sessions-status-inactive")">
                    @(Model.IsActive ? "Active" : "Inactive")
                </span>
            </div>
        </div>

        <div class="session-details-grid two-cols">
            <section class="session-details-card">
                <h3>Planning</h3>
                <dl class="session-details-list">
                    <div>
                        <dt>Date</dt>
                        <dd>@Model.SessionDate.ToString("dd/MM/yyyy")</dd>
                    </div>
                    <div>
                        <dt>Start Time</dt>
                        <dd>@Model.StartTime.ToString("HH:mm")</dd>
                    </div>
                    <div>
                        <dt>End Time</dt>
                        <dd>@Model.EndTime.ToString("HH:mm")</dd>
                    </div>
                    <div>
                        <dt>Status</dt>
                        <dd>@Model.Status</dd>
                    </div>
                </dl>
            </section>

            <section class="session-details-card">
                <h3>Assignments</h3>
                <dl class="session-details-list">
                    <div>
                        <dt>Teacher</dt>
                        <dd>@(Model.Teacher?.User?.FullName ?? "-")</dd>
                    </div>
                    <div>
                        <dt>Subject</dt>
                        <dd>@(Model.Subject != null ? Model.Subject.Name + " (" + Model.Subject.Code + ")" : "-")</dd>
                    </div>
                    <div>
                        <dt>Room</dt>
                        <dd>@(Model.Room != null ? Model.Room.Name : "-")</dd>
                    </div>
                </dl>
            </section>
        </div>

        <section class="session-details-card">
            <h3>Audit Info</h3>
            <dl class="session-details-list two-cols">
                <div>
                    <dt>Created At</dt>
                    <dd>@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                </div>
                <div>
                    <dt>Updated At</dt>
                    <dd>@Model.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                </div>
            </dl>
        </section>
    </div>
</section>
