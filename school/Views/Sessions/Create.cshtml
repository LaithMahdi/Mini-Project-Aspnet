@model school.Models.Session

@{
    ViewData["Title"] = "Create Session";

    var statusOptions = ViewBag.StatusOptions as SelectList;
    var roomOptions = ViewBag.RoomOptions as SelectList;
    var subjectOptions = ViewBag.SubjectOptions as SelectList;
    var teacherOptions = ViewBag.TeacherOptions as SelectList;
}

<section class="session-form-page">
    <div class="session-form-header">
        <div>
            <h1>Create Session</h1>
            <p class="session-form-subtitle">Set day, time range, room, teacher, and subject.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to List</a>
    </div>

    <div class="session-form-shell">
        <form asp-action="Create" method="post" class="session-form-grid">
            <div asp-validation-summary="ModelOnly" class="session-validation"></div>

            <div class="session-form-fields">
                <input type="hidden" asp-for="StartTime" />
                <input type="hidden" asp-for="EndTime" />

                <div class="form-group">
                    <label asp-for="SessionDate" class="control-label"></label>
                    <input asp-for="SessionDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="SessionDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="control-label">Time Slot</label>
                    <select id="SessionSlot" class="form-control" required>
                        <option value="">-- Select Time Slot --</option>
                        @foreach (var slot in ViewBag.SessionSlots)
                        {
                            <option value="@slot.Value">@slot.Text</option>
                        }
                    </select>
                    <small class="form-text text-muted">Each session is 90 minutes. Breaks: 10:00-10:10, 11:40-12:10, 13:40-13:50</small>
                </div>

                <div class="form-group">
                    <label asp-for="Status" class="control-label"></label>
                    <select asp-for="Status" class="form-control" asp-items="statusOptions"></select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="form-group full-col">
                    <label asp-for="TeacherId" class="control-label"></label>
                    <select asp-for="TeacherId" class="form-control" asp-items="teacherOptions"></select>
                    <span asp-validation-for="TeacherId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SubjectId" class="control-label"></label>
                    <select asp-for="SubjectId" class="form-control" asp-items="subjectOptions"></select>
                    <span asp-validation-for="SubjectId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RoomId" class="control-label"></label>
                    <select asp-for="RoomId" class="form-control" asp-items="roomOptions"></select>
                    <span asp-validation-for="RoomId" class="text-danger"></span>
                </div>

                <div class="form-group full-col">
                    <label asp-for="ClassId" class="control-label"></label>
                    <select asp-for="ClassId" class="form-control" asp-items="ViewBag.ClassOptions"></select>
                    <span asp-validation-for="ClassId" class="text-danger"></span>
                </div>

                <div class="form-group full-col session-check-wrap">
                    <label class="session-check-control">
                        <input class="form-check-input" asp-for="IsActive" />
                        <span>Session is active</span>
                    </label>
                </div>
            </div>

            <div class="session-form-actions">
                <button type="submit" class="btn btn-primary">Create Session</button>
                <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const form = document.querySelector('form[asp-action="Create"]');
            const slotSelect = document.getElementById('SessionSlot');
            const startTimeInput = document.getElementsByName('StartTime')[0];
            const endTimeInput = document.getElementsByName('EndTime')[0];

            if (slotSelect && startTimeInput && endTimeInput) {
                // When slot is selected, populate start/end times
                slotSelect.addEventListener('change', function () {
                    if (this.value) {
                        const [startTime, endTime] = this.value.split('-');
                        startTimeInput.value = startTime;
                        endTimeInput.value = endTime;

                        // Update HTML5 time input format (needed for proper validation)
                        startTimeInput.dispatchEvent(new Event('change', { bubbles: true }));
                        endTimeInput.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                });

                // Validate on form submit
                form.addEventListener('submit', function (e) {
                    if (!slotSelect.value) {
                        e.preventDefault();
                        alert('Please select a time slot');
                        slotSelect.focus();
                    }
                });
            }
        })();
    </script>
}
