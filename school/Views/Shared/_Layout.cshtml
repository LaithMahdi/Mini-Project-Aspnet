<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - school</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/school.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="min-h-screen flex">
        <aside class="w-64 bg-slate-900 text-slate-100 p-5 flex flex-col">
            <a class="text-white text-2xl font-bold mb-6" asp-area="" asp-controller="Home" asp-action="Index">school</a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="mb-4 rounded-xl bg-slate-800 p-3 text-sm">
                    <div class="text-slate-400">Connected as</div>
                    <div class="font-semibold text-white">@User.Identity.Name</div>
                </div>

                <nav class="flex-1 space-y-1">
                    <a class="block rounded-lg px-3 py-2 hover:bg-slate-800 text-slate-200" asp-controller="Home" asp-action="Index">Dashboard</a>
                    <a class="block rounded-lg px-3 py-2 hover:bg-slate-800 text-slate-200" asp-controller="Users" asp-action="Index">Users</a>
                    <a class="block rounded-lg px-3 py-2 hover:bg-slate-800 text-slate-200" asp-controller="Teachers" asp-action="Index">Teachers</a>
                    <a class="block rounded-lg px-3 py-2 hover:bg-slate-800 text-slate-200" asp-controller="Students" asp-action="Index">Students</a>
                    <a class="block rounded-lg px-3 py-2 hover:bg-slate-800 text-slate-200" asp-controller="Sections" asp-action="Index">Sections</a>
                    <a class="block rounded-lg px-3 py-2 hover:bg-slate-800 text-slate-200" asp-controller="Classes" asp-action="Index">Classes</a>
                    <a class="block rounded-lg px-3 py-2 hover:bg-slate-800 text-slate-200" asp-controller="Subjects" asp-action="Index">Subjects</a>
                    <a class="block rounded-lg px-3 py-2 hover:bg-slate-800 text-slate-200" asp-controller="Rooms" asp-action="Index">Rooms</a>
                    <a class="block rounded-lg px-3 py-2 hover:bg-slate-800 text-slate-200" asp-controller="Sessions" asp-action="Index">Sessions</a>
                </nav>

                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-5">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full rounded-lg border border-slate-700 px-3 py-2 text-sm text-slate-100 hover:bg-slate-800">Logout</button>
                </form>
            }
            else
            {
                <a class="rounded-lg border border-slate-700 px-3 py-2 text-sm text-slate-100 hover:bg-slate-800" asp-controller="Account" asp-action="Login">Login</a>
            }
        </aside>

        <div class="flex-1 p-6 lg:p-8">
            <main role="main" class="page-card">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
