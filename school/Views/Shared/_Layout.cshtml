<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - school</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-slate-100">
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    }
<div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="fixed top-0 left-0 h-screen w-64 bg-slate-900 text-slate-100 flex flex-col">

        <!-- Top (Logo) -->
        <div class="p-5 border-b border-slate-800">
            <a class="text-2xl font-bold text-white" asp-controller="Home" asp-action="Index">
                School
            </a>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <!-- User Info -->
            <div class="p-4">
                <div class="bg-slate-800 rounded-xl p-3 text-sm">
                    <div class="text-slate-400">Connected as</div>
                    <div class="font-semibold text-white">@User.Identity.Name</div>
                </div>
            </div>

            <!-- 🔥 Scrollable Menu ONLY -->
            <nav class="flex-1 overflow-hidden px-3 space-y-1">

                @{
                    Func<string, string> isActive = (controller) =>
                        currentController == controller
                        ? "bg-indigo-600 text-white"
                        : "text-slate-300 hover:bg-slate-800";
                }

                <a class="block px-3 py-2 rounded-lg @isActive("Home")" asp-controller="Home" asp-action="Index">Dashboard</a>
                <a class="block px-3 py-2 rounded-lg @isActive("Users")" asp-controller="Users" asp-action="Index">Users</a>
                <a class="block px-3 py-2 rounded-lg @isActive("Sections")" asp-controller="Sections" asp-action="Index">Sections</a>
                <a class="block px-3 py-2 rounded-lg @isActive("Classes")" asp-controller="Classes" asp-action="Index">Classes</a>
                <a class="block px-3 py-2 rounded-lg @isActive("Subjects")" asp-controller="Subjects" asp-action="Index">Subjects</a>
                <a class="block px-3 py-2 rounded-lg @isActive("Rooms")" asp-controller="Rooms" asp-action="Index">Rooms</a>
                <a class="block px-3 py-2 rounded-lg @isActive("Sessions")" asp-controller="Sessions" asp-action="Index">Sessions</a>

            </nav>

            <!-- Bottom (Logout always visible) -->
            <div class="p-4 border-t border-slate-800">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button class="w-full px-3 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm">
                        Logout
                    </button>
                </form>
            </div>
        }
    </aside>

    <!-- Main Content -->
    <div class="ml-64 flex-1 h-screen overflow-y-auto">

        <div class="p-6 lg:p-10 pb-12">
            <main class="bg-white rounded-2xl shadow-sm p-6">
                @RenderBody()
            </main>
        </div>

    </div>

</div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>