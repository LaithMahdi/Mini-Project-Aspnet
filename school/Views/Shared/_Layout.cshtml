@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentControllerLower = currentController.ToLowerInvariant();
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isTeacher = User.IsInRole("Teacher");
    var isAdmin = User.IsInRole("Admin");
    var isStudent = User.IsInRole("Student");
    var moduleCssPath = currentControllerLower switch
    {
        "home" => "~/css/modules/home.css",
        "users" => "~/css/modules/users.css",
        "students" => "~/css/modules/users.css",
        "sections" => "~/css/modules/sections.css",
        "classes" => "~/css/modules/classes.css",
        "subjects" => "~/css/modules/subjects.css",
        "rooms" => "~/css/modules/rooms.css",
        "sessions" => "~/css/modules/sessions.css",
        _ => null
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - school</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (!string.IsNullOrWhiteSpace(moduleCssPath))
    {
        <link rel="stylesheet" href="@moduleCssPath" asp-append-version="true" />
    }
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="app-body">
<div class="app-layout">
    @if (isAuthenticated)
    {
        <aside class="app-sidebar">
            <div class="sidebar-header">
                <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-school"></i>
                    <span>School Management</span>
                </a>
            </div>

            <nav class="sidebar-scroll">
                @{
                    Func<string, string> navClass = (controller) =>
                        currentController == controller
                        ? "sidebar-nav-link sidebar-nav-link-active"
                        : "sidebar-nav-link sidebar-nav-link-idle";
                }

                <a class="@navClass("Home")" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-house"></i>
                    <span>@(isStudent ? "Mon Emploi" : "Dashboard")</span>
                </a>

                @if (isAdmin || isTeacher)
                {
                    <a class="@navClass("Classes")" asp-controller="Classes" asp-action="Index"><i class="fa-solid fa-chalkboard"></i><span>Classes</span></a>
                }

                @if (isTeacher)
                {
                    <a class="@navClass("Students")" asp-controller="Students" asp-action="Index"><i class="fa-solid fa-user-graduate"></i><span>Students</span></a>
                }

                <a class="@navClass("Notifications")" asp-controller="Notifications" asp-action="Index">
                    <i class="fa-solid fa-bell"></i>
                    <span>Notifications</span>
                    @await Component.InvokeAsync("NotificationCount")
                </a>

                @if (isAdmin || isTeacher)
                {
                    <a class="@navClass("Sessions")" asp-controller="Sessions" asp-action="Index"><i class="fa-solid fa-calendar-days"></i><span>Sessions</span></a>
                }
                @if (isAdmin)
                {
                    <a class="@navClass("Users")" asp-controller="Users" asp-action="Index"><i class="fa-solid fa-users-gear"></i><span>Users</span></a>
                    <a class="@navClass("Sections")" asp-controller="Sections" asp-action="Index"><i class="fa-solid fa-layer-group"></i><span>Sections</span></a>
                    <a class="@navClass("Subjects")" asp-controller="Subjects" asp-action="Index"><i class="fa-solid fa-book-open"></i><span>Subjects</span></a>
                    <a class="@navClass("Rooms")" asp-controller="Rooms" asp-action="Index"><i class="fa-solid fa-door-open"></i><span>Rooms</span></a>
                }
            </nav>

            <div class="sidebar-footer">
                <div class="sidebar-user-card">
                    <div class="sidebar-user-role">Connected User</div>
                    <div class="sidebar-user-name">@User.Identity?.Name</div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="sidebar-logout-form">
                    @Html.AntiForgeryToken()
                    <button class="sidebar-logout-btn" type="submit">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </div>
        </aside>
    }

    <div class="app-main @(isAuthenticated ? "app-main-with-sidebar" : "app-main-full")">
        <main class="main-scroll-area">
            <section class="content-shell">
                @RenderBody()
            </section>
        </main>
    </div>
</div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>