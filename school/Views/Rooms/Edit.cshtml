@model school.Models.Room

@{
    ViewData["Title"] = "Edit Room";

    var roomTypeOptions = ViewBag.RoomTypeOptions as SelectList;
}

<section class="room-form-page">
    <div class="room-form-header">
        <div>
            <h1>Edit Room</h1>
            <p class="room-form-subtitle">Update room properties and availability settings.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-light">Back to List</a>
    </div>

    <div class="room-form-shell">
        <form asp-action="Edit" class="room-form-grid">
            <div asp-validation-summary="ModelOnly" class="room-validation"></div>
            <input type="hidden" asp-for="Id" />

            <div class="room-form-fields">
                <div class="form-group">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Type" class="control-label"></label>
                    <select asp-for="Type" class="form-control" asp-items="roomTypeOptions"></select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Capacity" class="control-label"></label>
                    <input asp-for="Capacity" class="form-control" />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Building" class="control-label"></label>
                    <input asp-for="Building" class="form-control" />
                    <span asp-validation-for="Building" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Floor" class="control-label"></label>
                    <input asp-for="Floor" class="form-control" />
                    <span asp-validation-for="Floor" class="text-danger"></span>
                </div>

                <div class="form-group full-col">
                    <label asp-for="Equipment" class="control-label"></label>
                    <input asp-for="Equipment" class="form-control" />
                    <span asp-validation-for="Equipment" class="text-danger"></span>
                </div>

                <div class="room-check-grid full-col">
                    <label class="room-check-control">
                        <input class="form-check-input" asp-for="HasProjector" />
                        <span>Has projector</span>
                    </label>
                    <label class="room-check-control">
                        <input class="form-check-input" asp-for="HasComputers" />
                        <span>Has computers</span>
                    </label>
                    <label class="room-check-control">
                        <input class="form-check-input" asp-for="IsAvailable" />
                        <span>Available for scheduling</span>
                    </label>
                </div>
            </div>

            <div class="room-form-meta">
                <span><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                <span><strong>Updated:</strong> @Model.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
            </div>

            <div class="room-form-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
